<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Dashboard</h1>
    <p class="text-gray-600">Welcome, <%= Current.user.email_address %></p>
  </div>

  <!-- Stats -->
  <div class="bg-white rounded-lg shadow p-6 mb-8">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-600 mb-1">Total Commits</p>
        <p class="text-3xl font-bold text-blue-600"><%= @total_commits %></p>
      </div>
      <div>
        <%= link_to "Settings", settings_path, class: "text-blue-600 hover:text-blue-700 font-medium" %>
      </div>
    </div>
  </div>

  <!-- Commits List -->
  <div class="bg-white rounded-lg shadow">
    <div class="px-6 py-4 border-b border-gray-200">
      <div class="flex justify-between items-center">
        <h2 class="text-xl font-semibold text-gray-900">Recent Commits</h2>
        <% if @repositories.any? %>
          <form method="get" action="<%= dashboard_path %>" data-turbo-frame="commits-list">
            <select name="repository_id" class="border border-gray-300 rounded px-3 py-1 text-sm" data-turbo-action="advance" onchange="this.form.requestSubmit()">
              <option value="">All Repositories</option>
              <% @repositories.each do |repo| %>
                <option value="<%= repo.id %>" <%= 'selected' if params[:repository_id] == repo.id.to_s %>>
                  <%= repo.name || repo.url %>
                </option>
              <% end %>
            </select>
          </form>
        <% end %>
      </div>
    </div>

    <%= turbo_frame_tag "commits-list" do %>
      <% if @commits.any? %>
        <div class="space-y-6">
          <% @commits.each do |commit| %>
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow" data-controller="expandable">
              <!-- Header with title and metadata -->
              <div class="flex items-start justify-between gap-6 mb-4">
                <h3 class="text-lg font-semibold text-gray-900 flex-1"><%= commit.message.lines.first&.strip %></h3>
                <div class="text-right flex-shrink-0">
                  <div class="text-xs text-gray-500"><%= time_ago_in_words(commit.created_at) %> ago</div>
                  <div class="text-xs text-gray-400 mt-1">
                    <code class="bg-gray-100 px-2 py-1 rounded text-gray-700"><%= commit.commit_hash.truncate(12) %></code>
                  </div>
                </div>
              </div>

              <!-- Two-column layout for summary and details -->
              <div class="commit-details-grid">
                <!-- Left column: Summary -->
                <div>
                  <% if commit.summary.present? %>
                    <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Summary</div>
                    <p class="text-sm text-gray-700"><%= commit.summary %></p>
                  <% end %>
                </div>

                <!-- Right column: Details -->
                <div>
                  <% if commit.message.lines.count > 1 %>
                    <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-2">Details</div>
                    <div class="text-sm text-gray-700 leading-relaxed commit-message-content" data-expandable-target="content"><%= commit.message.lines[1..-1].join.strip %></div>
                    <button type="button" class="text-sm text-blue-600 hover:text-blue-700 mt-2 hidden" data-expandable-target="toggle" data-action="click->expandable#toggle">More...</button>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Pagination -->
        <% if @pagy.pages > 1 %>
          <div class="px-6 py-4 border-t border-gray-200 flex justify-center">
            <%== pagy_tailwind_nav(@pagy) %>
          </div>
        <% end %>
      <% else %>
        <div class="px-6 py-12 text-center">
          <p class="text-gray-500 mb-4">No commits yet</p>
          <p class="text-sm text-gray-400">Commits will appear here when you start using the CLI</p>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
